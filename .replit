modules = ["nodejs-24", "php", "php-8.4"]

[deployment]
router = "application"
deploymentTarget = "autoscale"
run = ["sh", "-c", "php -S 0.0.0.0:22887 -t php-web/public"]


[workflows]
runButton = "Project"

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[[ports]]
localPort = 22887
externalPort = 80

[agent]
expertMode = true
